# ── Dashboard Outbound Pró Vendas — Variáveis de Ambiente ──────────────────────
# Copie este arquivo para .env e preencha os valores

# Chave de API do Pipedrive
# Encontre em: Configurações → Pessoal → Chave de API
PIPEDRIVE_API_KEY=sua_chave_aqui

# URL do Google Apps Script Web App
# Obtida após fazer o deploy do apps_script.gs como Web App
WEBAPP_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec

# Segredo compartilhado entre Python e Apps Script
WEBAPP_SECRET=routesales2026

# IDs dos pipelines no Pipedrive
# Consulte: GET https://api.pipedrive.com/v1/pipelines?api_token=SUA_CHAVE
PRESALES_PIPELINE_ID=1
SALES_PIPELINE_ID=2
